{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "plexi",
  "version": "0.1.0",
  "identifier": "dev.plexi",
  "build": {
    "devUrl": "http://localhost:1415/mainview/",
    "frontendDist": "../src/mainview",
    "beforeDevCommand": "python3 -m http.server 1415 --bind 127.0.0.1 --directory src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Plexi",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
