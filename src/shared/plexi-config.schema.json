{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plexi Config",
  "type": "object",
  "required": ["version", "workspace", "terminal", "keyboard"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "workspace": {
      "type": "object",
      "required": ["title", "camera", "contexts", "activeContextIndex", "sequence"],
      "properties": {
        "title": {
          "type": "string"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "activeContextIndex": {
          "type": "integer",
          "minimum": 0
        },
        "sidebarVisible": {
          "type": "boolean"
        },
        "minimapVisible": {
          "type": "boolean"
        },
        "camera": {
          "type": "object",
          "required": ["x", "y", "zoom"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "zoom": {
              "type": "number",
              "minimum": 0.25,
              "maximum": 3
            }
          }
        },
        "contexts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "label", "panels", "activePanelId"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "pinned": { "type": "boolean" },
              "activeNodeId": {
                "type": ["string", "null"]
              },
              "activePanelId": {
                "type": ["string", "null"]
              },
              "nodes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "type", "x", "y", "activePaneId", "panes"],
                  "properties": {
                    "id": { "type": "string" },
                    "type": {
                      "type": "string",
                      "enum": ["single", "split-group"]
                    },
                    "label": { "type": "string" },
                    "x": { "type": "number" },
                    "y": { "type": "number" },
                    "activePaneId": {
                      "type": ["string", "null"]
                    },
                    "layout": {
                      "type": ["object", "null"]
                    },
                    "panes": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "object",
                        "required": ["id", "type", "title", "cwd", "cwdLabel"],
                        "properties": {
                          "id": { "type": "string" },
                          "type": {
                            "type": "string",
                            "enum": ["terminal", "browser"]
                          },
                          "title": { "type": "string" },
                          "cwd": { "type": "string" },
                          "cwdLabel": { "type": "string" },
                          "fontSize": { "type": "number", "minimum": 8 },
                          "splitX": { "type": "number" },
                          "splitY": { "type": "number" },
                          "splitWidth": { "type": "number" },
                          "splitHeight": { "type": "number" }
                        }
                      }
                    }
                  }
                }
              },
              "panels": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "type", "title", "x", "y", "cwd", "cwdLabel"],
                  "properties": {
                    "id": { "type": "string" },
                    "type": {
                      "type": "string",
                      "enum": ["terminal", "browser"]
                    },
                    "title": { "type": "string" },
                    "x": { "type": "number" },
                    "y": { "type": "number" },
                    "cwd": { "type": "string" },
                    "cwdLabel": { "type": "string" },
                    "fontSize": { "type": "number", "minimum": 8 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "terminal": {
      "type": "object",
      "required": ["engine", "fontFamily", "fontSize", "cursorStyle", "theme"],
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["xterm", "libghostty"]
        },
        "fontFamily": {
          "type": "string"
        },
        "fontSize": {
          "type": "number",
          "minimum": 8
        },
        "cursorStyle": {
          "type": "string",
          "enum": ["block", "bar", "underline"]
        },
        "theme": {
          "type": "string"
        }
      }
    },
    "keyboard": {
      "type": "object"
    }
  }
}
