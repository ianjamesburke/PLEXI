{
  "name": "plexi",
  "version": "0.1.0",
  "description": "Infinite 2D canvas terminal multiplexer",
  "scripts": {
    "start": "electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:clean": "bun run scripts/dev-clean.ts",
    "build": "electrobun build",
    "test": "bun test ./tests/unit/*.test.ts",
    "test:e2e": "bun run build && playwright test",
    "verify": "bun run test && bun run test:e2e"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "bun-pty": "^0.4.8",
    "electrobun": "^1.15.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest"
  }
}
