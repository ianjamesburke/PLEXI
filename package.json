{
  "name": "plexi",
  "version": "0.1.0",
  "description": "Infinite 2D canvas terminal multiplexer",
  "scripts": {
    "copy-vendor": "node -e \"const fs=require('fs');const p='src/mainview/vendor/ghostty';fs.mkdirSync(p,{recursive:true});['ghostty-web.js:node_modules/ghostty-web/dist/ghostty-web.js','ghostty-vt.wasm:node_modules/ghostty-web/ghostty-vt.wasm'].forEach(e=>{const[d,s]=e.split(':');fs.copyFileSync(s,p+'/'+d)});console.log('vendor assets copied')\"",
    "start": "tauri dev",
    "dev": "tauri dev",
    "build": "tauri build",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:e2e": "playwright test",
    "test:e2e:binary": "wdio run wdio.conf.ts",
    "test:e2e:binary:build": "cd src-tauri && cargo build --features webdriver && cd .. && wdio run wdio.conf.ts",
    "verify": "npm run test:rust && npm run test:e2e"
  },
  "dependencies": {
    "ghostty-web": "^0.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/bun": "latest",
    "@wdio/cli": "^9.26.1",
    "@wdio/local-runner": "^9.26.1",
    "@wdio/mocha-framework": "^9.26.1",
    "@wdio/spec-reporter": "^9.26.1"
  }
}
